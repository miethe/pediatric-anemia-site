{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://research-foundry.example/schemas/rights_extension.schema.json",
  "title": "Research/Evidence Foundry Rights Extension",
  "description": "Embed this object under extensions.rights in source records, evidence atoms, candidate rules, questionnaires, or roadmap objects.",
  "type": "object",
  "additionalProperties": false,
  "required": ["rights_record_ids", "clearance_status", "release_gate", "last_reviewed_at"],
  "properties": {
    "rights_record_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "reuse_assessment_ids": {"type": "array", "items": {"type": "string"}},
    "permission_record_ids": {"type": "array", "items": {"type": "string"}},
    "rights_failure_ids": {"type": "array", "items": {"type": "string"}},
    "clearance_status": {
      "enum": [
        "CLEARED_OPEN_LICENSE",
        "CLEARED_PUBLIC_DOMAIN",
        "CLEARED_FACTS_ONLY",
        "CLEARED_PERMISSION",
        "INTERNAL_ONLY",
        "LOCAL_VALIDATION_ONLY",
        "LEGAL_REVIEW_REQUIRED",
        "PERMISSION_REQUIRED",
        "CONTRACT_RESTRICTED",
        "PROHIBITED",
        "UNKNOWN"
      ]
    },
    "release_gate": {"enum": ["PASS", "PASS_WITH_CONDITIONS", "BLOCK"]},
    "shippable_claim_text_allowed": {"type": ["boolean", "null"]},
    "verbatim_excerpt_allowed": {"type": ["boolean", "null"]},
    "source_locator_display_allowed": {"type": ["boolean", "null"]},
    "publisher_content_dependency": {"enum": ["none", "low", "moderate", "high", "unknown"]},
    "compilation_similarity": {"enum": ["none", "low", "moderate", "high", "near_identical", "unknown"]},
    "permission_required_before_release": {"type": ["boolean", "null"]},
    "last_reviewed_at": {"type": "string", "format": "date-time"},
    "expires_at": {"type": ["string", "null"], "format": "date-time"},
    "notes": {"type": ["string", "null"]}
  }
}
