node_modules/
dist/
*.zip
.DS_Store

# Evidence Foundry converter output (tools/rf-bundle-to-kb-pack/); generated, never committed.
# Committed golden/fixture outputs for converter tests live under tests/fixtures/ instead (OQ-6).
build/

# Evidence Foundry retrospective-validation access log (tools/retro-validate/, FR-22, P4-T7):
# runtime-generated audit trail from real invocations, never committed. Tests exercise the
# access-log module against isolated tmp paths (see tests/ef-retro-access-log.test.mjs), never this
# path, so this file should never actually be produced by `npm test`/`npm run check`.
tools/retro-validate/access-log.jsonl

# AOS local state (deploy tracking + writeback markers + operator run records); keep committed
# workflow artifacts under .claude/, ignore local/runtime state. Run IDs are referenced in the docs.
.claude/.aos-writeback-state
.claude/.skillmeat-deployed.toml
.operator/
__pycache__/

# git worktrees created by EnterWorktree / dev-execution protocol
.claude/worktrees/
.claude/agent-memory/

# Clinical Review Workflow v1 staging area (tools/review-record, P1-T3(c)/P2-T1, F1/CRW-F2):
# `scaffold --draft` writes an unsigned draft record here, outside modules/<id>/reviews/; `sign`
# reads ONLY from this path and never opens/rewrites a path already inside reviews/. Ephemeral
# scratch space, never git-tracked, never a committed review record.
.review-drafts/
