    {
      "id": "iron-deficiency-anemia",
      "label": "Iron deficiency anemia pattern",
      "category": "microcytic / nutritional or blood loss",
      "summary": "Anemia with biochemical or pattern evidence of iron deficiency. Ferritin below the age/menstrual threshold is the strongest built-in criterion.",
      "defaultNextSteps": [
        "Identify the source: dietary insufficiency, excessive cow milk, menstrual/GI/other blood loss, malabsorption, or increased requirement.",
        "Review ferritin in inflammatory context and use local assay units/reference intervals.",
        "If the course is atypical or response is inadequate, reassess adherence, ongoing blood loss, malabsorption, inflammation, thalassemia, lead, and alternative diagnoses."
      ],
      "evidence": [
        "AAP2026_IDA",
        "BLOOD2022_PED_ANEMIA"
      ],
      "sourcePassageId": "AAP2026_IDA#implementation-proposal",
