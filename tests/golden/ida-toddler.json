      "score": 165,
      "matchedRules": [
        "ID-001",
        "ID-006"
      ],
      "supportingFindings": [
        "Hemoglobin 8.4 g/dL is below the effective lower limit of 11 g/dL.",
        "Ferritin 6 ng/mL is at or below the AAP threshold of 20 ng/mL.",
        "Microcytic anemia, locally interpreted low transferrin saturation, and an iron-risk history were supplied."
      ],
      "cautions": [],
      "nextSteps": [
        "Identify the source: dietary insufficiency, excessive cow milk, menstrual/GI/other blood loss, malabsorption, or increased requirement.",
        "Review ferritin in inflammatory context and use local assay units/reference intervals.",
        "If the course is atypical or response is inadequate, reassess adherence, ongoing blood loss, malabsorption, inflammation, thalassemia, lead, and alternative diagnoses."
      ],
      "rank": 1
    },
    {
      "id": "lead-exposure-associated-anemia",
      "label": "Lead exposure requiring a lead clinical pathway",
      "category": "toxic / microcytic anemia contributor",
      "summary": "A blood lead level at or above the CDC blood lead reference value requires exposure follow-up; lead may coexist with iron deficiency and can contribute to anemia.",
      "defaultNextSteps": [
        "If the elevated result is capillary, obtain confirmatory venous testing on the CDC timeline.",
        "Take an environmental exposure history and involve public health/environmental services as indicated.",
        "Assess and address coexisting iron deficiency."
