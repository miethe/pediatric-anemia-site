  "rankedDifferential": [
    {
      "id": "anemia-of-inflammation",
      "label": "Anemia of inflammation / inflammatory iron restriction pattern",
      "category": "production-limited anemia",
      "summary": "Anemia associated with inflammation and an iron-restricted pattern in which ferritin may be normal or elevated.",
      "defaultNextSteps": [
        "Confirm and characterize the inflammatory condition and trend CBC, ferritin, CRP/ESR, transferrin saturation, and TIBC using local interpretation.",
        "Assess for coexisting absolute iron deficiency; a low ferritin remains important even with inflammation."
      ],
      "evidence": [
        "AAP2026_IDA",
        "BLOOD2022_PED_ANEMIA"
      ],
      "sourcePassageId": "AAP2026_IDA#implementation-proposal",
      "level": "strongly-supported",
      "score": 285,
      "matchedRules": [
        "AINF-001",
        "AINF-002",
        "AINF-003",
        "AINF-004"
      ],
      "supportingFindings": [
        "Anemia, elevated CRP, non-low ferritin, low transferrin saturation, and low/normal TIBC form an inflammatory iron-restriction pattern.",
        "Chronic inflammatory disease, non-low ferritin, and an inappropriately low reticulocyte response were supplied.",
        "sTfR/log10(ferritin) index is <1 with elevated CRP, favoring anemia of inflammation without absolute iron deficiency.",
        "Normocytic, production-limited anemia occurs with a chronic inflammatory condition."
      ],
      "cautions": [],
      "nextSteps": [
        "Confirm and characterize the inflammatory condition and trend CBC, ferritin, CRP/ESR, transferrin saturation, and TIBC using local interpretation.",
        "Assess for coexisting absolute iron deficiency; a low ferritin remains important even with inflammation."
      ],
      "rank": 1
    }
  ],
  "nextQuestions": [],
  "interpretiveNotes": [
    {
      "id": "NOTE-002",
      "title": "Ferritin is inflammation-confounded",
      "detail": "Ferritin is not low and CRP is elevated. A normal or high ferritin cannot reliably exclude iron deficiency in this context; use the full iron/inflammation pattern and, when available, the sTfR/log10(ferritin) index.",
      "evidence": [
        "AAP2026_IDA"
      ]
    }
