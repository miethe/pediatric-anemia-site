      "id": "ALERT-LEAD-CAPILLARY",
      "severity": "important",
      "title": "Elevated capillary lead screen requires venous confirmation",
      "detail": "The capillary blood lead level is at or above 3.5 µg/dL. CDC guidance calls for confirmatory venous testing on a level-dependent timeline.",
      "actions": [
        "Arrange confirmatory venous testing using the current CDC/local timeline.",
        "Take an environmental exposure history and assess for coexisting iron deficiency."
      ],
      "evidence": [
        "CDC2025_LEAD"
      ]
    }
  ],
  "rankedDifferential": [
    {
      "id": "lead-exposure-associated-anemia",
      "label": "Lead exposure requiring a lead clinical pathway",
      "category": "toxic / microcytic anemia contributor",
      "summary": "A blood lead level at or above the CDC blood lead reference value requires exposure follow-up; lead may coexist with iron deficiency and can contribute to anemia.",
      "defaultNextSteps": [
        "If the elevated result is capillary, obtain confirmatory venous testing on the CDC timeline.",
        "Take an environmental exposure history and involve public health/environmental services as indicated.",
        "Assess and address coexisting iron deficiency."
      ],
      "evidence": [
        "CDC2025_LEAD",
        "AAP2026_IDA"
      ],
