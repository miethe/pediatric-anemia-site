{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://research-foundry.example/schemas/content_reuse_assessment.schema.json",
  "title": "Research Foundry Content Reuse Assessment",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "reuse_assessment_id",
    "source_id",
    "rights_record_ids",
    "component",
    "intended_use",
    "analysis",
    "decision",
    "review"
  ],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "reuse_assessment_id": {"type": "string", "minLength": 5},
    "source_id": {"type": "string", "minLength": 3},
    "rights_record_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}},
    "evidence_atom_ids": {"type": "array", "items": {"type": "string"}},
    "candidate_rule_ids": {"type": "array", "items": {"type": "string"}},
    "component": {
      "type": "object",
      "additionalProperties": false,
      "required": ["component_type", "description"],
      "properties": {
        "component_type": {
          "enum": [
            "bibliographic_metadata",
            "atomic_fact",
            "method",
            "equation",
            "guideline_recommendation",
            "reference_interval_value",
            "prose",
            "table",
            "figure",
            "chart",
            "nomogram",
            "decision_tree_or_flowchart",
            "questionnaire_or_instrument",
            "patient_handout",
            "dataset",
            "software_or_code",
            "image_or_media",
            "trademark_or_logo",
            "other"
          ]
        },
        "description": {"type": "string"},
        "source_locator": {"type": ["string", "null"]},
        "quantity_or_scope": {"type": ["string", "null"]}
      }
    },
    "intended_use": {
      "type": "object",
      "additionalProperties": false,
      "required": ["product", "use_type", "commercial", "audience", "channels", "territories"],
      "properties": {
        "product": {"type": "string"},
        "product_version": {"type": ["string", "null"]},
        "use_type": {
          "enum": [
            "internal_research",
            "controlled_archive",
            "evidence_registry",
            "rule_authoring",
            "commercial_runtime_logic",
            "commercial_user_facing_explanation",
            "clinician_source_preview",
            "patient_facing_content",
            "documentation",
            "marketing",
            "training",
            "bulk_retrieval",
            "text_and_data_mining",
            "model_training",
            "partner_distribution"
          ]
        },
        "commercial": {"type": "boolean"},
        "audience": {"type": "array", "items": {"type": "string"}},
        "channels": {"type": "array", "items": {"type": "string"}},
        "territories": {"type": "array", "items": {"type": "string"}},
        "term_start": {"type": ["string", "null"], "format": "date"},
        "term_end": {"type": ["string", "null"], "format": "date"}
      }
    },
    "analysis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "independently_authored",
        "copies_source_wording",
        "copies_source_arrangement",
        "compilation_similarity",
        "market_substitution_risk",
        "alternative_sources_available"
      ],
      "properties": {
        "independently_authored": {"type": "boolean"},
        "copies_source_wording": {"type": "boolean"},
        "copies_source_arrangement": {"type": "boolean"},
        "amount_and_substantiality": {"enum": ["minimal", "limited", "substantial", "complete", "unknown"]},
        "compilation_similarity": {"enum": ["none", "low", "moderate", "high", "near_identical", "unknown"]},
        "market_substitution_risk": {"enum": ["none", "low", "moderate", "high", "unknown"]},
        "alternative_sources_available": {"type": "boolean"},
        "alternative_source_ids": {"type": "array", "items": {"type": "string"}},
        "facts_methods_basis": {"type": ["string", "null"]},
        "contract_impact": {"type": ["string", "null"]},
        "patent_impact": {"type": ["string", "null"]},
        "trademark_impact": {"type": ["string", "null"]},
        "database_right_impact": {"type": ["string", "null"]},
        "privacy_confidentiality_impact": {"type": ["string", "null"]},
        "regulatory_transparency_need": {"type": ["string", "null"]},
        "attribution_plan": {"type": ["string", "null"]},
        "license_notice_plan": {"type": ["string", "null"]}
      }
    },
    "decision": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "release_gate", "rationale"],
      "properties": {
        "status": {
          "enum": [
            "CLEARED_OPEN_LICENSE",
            "CLEARED_PUBLIC_DOMAIN",
            "CLEARED_FACTS_ONLY",
            "CLEARED_PERMISSION",
            "INTERNAL_ONLY",
            "LOCAL_VALIDATION_ONLY",
            "LEGAL_REVIEW_REQUIRED",
            "PERMISSION_REQUIRED",
            "CONTRACT_RESTRICTED",
            "PROHIBITED",
            "UNKNOWN"
          ]
        },
        "release_gate": {"enum": ["PASS", "PASS_WITH_CONDITIONS", "BLOCK"]},
        "rationale": {"type": "string"},
        "conditions": {"type": "array", "items": {"type": "string"}},
        "required_permission_record_ids": {"type": "array", "items": {"type": "string"}},
        "rights_failure_ids": {"type": "array", "items": {"type": "string"}},
        "expires_at": {"type": ["string", "null"], "format": "date-time"}
      }
    },
    "review": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reviewed_at", "review_status"],
      "properties": {
        "agent_assessor": {"type": ["string", "null"]},
        "human_rights_reviewer": {"type": ["string", "null"]},
        "clinical_reviewer": {
          "type": ["string", "null"],
          "const": null,
          "description": "LOCAL AMENDMENT (EPR0-T3, D6): forced null in this feature. No clinical sign-off exists in this project and none may be agent-authored. See schemas/rights/VENDORING.md."
        },
        "counsel_reviewer": {"type": ["string", "null"]},
        "reviewed_at": {"type": "string", "format": "date-time"},
        "review_status": {
          "enum": ["agent_triage_only", "human_reviewed", "counsel_approved", "counsel_rejected", "expired"]
        },
        "next_review_at": {"type": ["string", "null"], "format": "date-time"}
      }
    },
    "extensions": {"type": "object"}
  }
}
